# Required — Supabase project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional — Public URL of this server (for OAuth redirect URIs)
# Defaults to Railway production domain if not set
EVIE_BASE_URL=https://your-domain.up.railway.app

# Optional — Server binding
PORT=8000
HOST=0.0.0.0
